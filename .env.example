NODE_ENV=development
HOST=0.0.0.0
PORT=10000
DATABASE_URL=postgresql://postgres:password@localhost:5432/undying_metro

# Точные адреса через запятую, без завершающего слеша.
CORS_ORIGINS=http://localhost:5500,https://serhiikharyponcuk.github.io

# Сгенерируйте независимые случайные значения длиной не менее 32 символов.
COOKIE_SECRET=replace-with-a-long-random-cookie-secret
TICKET_TOKEN_PEPPER=replace-with-a-long-random-ticket-pepper
REVIEW_CODE_PEPPER=replace-with-a-long-random-review-code-pepper
IP_HASH_SALT=replace-with-a-long-random-ip-hash-salt
SESSION_TTL_HOURS=24

# Cloudflare Turnstile. В production проверка обязательна.
TURNSTILE_REQUIRED=false
TURNSTILE_SECRET_KEY=

# Telegram Bot API. Можно указать несколько Chat ID через запятую.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=
ADMIN_PANEL_URL=https://undying-metro-api.onrender.com/admin/

# Если база ещё не содержит администраторов, сервер автоматически создаст первого
# при запуске. После успешного создания удалите обе переменные из окружения.
# Команда npm run admin:create остаётся доступной как ручной вариант.
ADMIN_INITIAL_USERNAME=
ADMIN_INITIAL_PASSWORD=
ADMIN_INITIAL_ROLE=admin
