generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum TicketStatus {
  open
  in_progress
  waiting_user
  closed
}

enum ContactType {
  telegram
  email
}

enum TicketCategory {
  purchase
  payment
  product_problem
  partnership
  complaint
  other
}

enum MessageSender {
  user
  admin
}

enum NotificationStatus {
  sent
  failed
  skipped
}

enum OrderCurrency {
  UAH
  EUR
  USD
}

enum EscortOrderStatus {
  planned
  completed
  paid
  cancelled
}

enum ExchangeRateSource {
  uah
  nbu
  manual
}

enum AdminSessionAccessMode {
  operator
  observer
}

enum AdminRole {
  owner
  director
  admin
  observer
}

model Admin {
  id              String           @id @default(uuid())
  username        String           @unique @db.VarChar(64)
  passwordHash    String           @map("password_hash")
  role            AdminRole        @default(admin)
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  sessions        AdminSession[]
  moderated       Review[]         @relation("ReviewModerator")
  assigned        SupportTicket[]  @relation("TicketAssignee")
  supportReplies  SupportMessage[] @relation("MessageAdmin")
  escortOrders    EscortOrder[]    @relation("EscortOrderCreator")
  escortPenalties EscortPenalty[]  @relation("EscortPenaltyAdmin")
  auditLogs       AuditLog[]       @relation("AuditLogAdmin")

  @@map("admins")
}

model EscortOrder {
  id                   String              @id @default(uuid())
  item                 String              @db.VarChar(160)
  buyerName            String              @map("buyer_name") @db.VarChar(64)
  buyerContact         String?             @map("buyer_contact") @db.VarChar(128)
  buyerGameId          String?             @map("buyer_game_id") @db.VarChar(20)
  reviewCodeHash       String?             @unique @map("review_code_hash") @db.VarChar(64)
  reviewCodeIssuedAt   DateTime?           @map("review_code_issued_at")
  reviewCodeConsumedAt DateTime?           @map("review_code_consumed_at")
  originalAmountMinor  BigInt              @map("original_amount_minor")
  currency             OrderCurrency
  exchangeRateMicros   BigInt              @map("exchange_rate_micros")
  rateSource           ExchangeRateSource  @map("rate_source")
  amountUahMinor       BigInt              @map("amount_uah_minor")
  developerAmountMinor BigInt              @map("developer_amount_minor")
  directorAmountMinor  BigInt              @default(0) @map("director_amount_minor")
  creatorAmountMinor   BigInt              @default(0) @map("creator_amount_minor")
  escortPoolMinor      BigInt              @map("escort_pool_minor")
  orderDate            DateTime            @map("order_date") @db.Date
  status               EscortOrderStatus   @default(planned)
  createdById          String              @map("created_by_id")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  createdBy            Admin               @relation("EscortOrderCreator", fields: [createdById], references: [id], onDelete: Restrict)
  participants         EscortParticipant[]
  review               Review?

  @@index([status, orderDate])
  @@index([buyerGameId, status])
  @@index([createdById])
  @@map("escort_orders")
}

model EscortParticipant {
  id               String               @id @default(uuid())
  orderId          String               @map("order_id")
  name             String               @db.VarChar(64)
  contact          String?              @db.VarChar(128)
  playerProfileId  String?              @map("player_profile_id")
  shareUahMinor    BigInt               @map("share_uah_minor")
  active           Boolean              @default(true)
  paid             Boolean              @default(false)
  paidAt           DateTime?            @map("paid_at")
  replacedAt       DateTime?            @map("replaced_at")
  excludedAt       DateTime?            @map("excluded_at")
  replacementForId String?              @unique @map("replacement_for_id")
  createdAt        DateTime             @default(now()) @map("created_at")
  order            EscortOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  playerProfile    EscortPlayerProfile? @relation(fields: [playerProfileId], references: [id], onDelete: SetNull)
  penalties        EscortPenalty[]
  replacementFor   EscortParticipant?   @relation("ParticipantReplacement", fields: [replacementForId], references: [id], onDelete: SetNull)
  replacement      EscortParticipant?   @relation("ParticipantReplacement")

  @@index([orderId])
  @@index([playerProfileId])
  @@map("escort_participants")
}

model EscortPenalty {
  id              String               @id @default(uuid())
  participantId   String               @map("participant_id")
  playerProfileId String?              @map("player_profile_id")
  sequence        Int
  violationDate   DateTime?            @map("violation_date") @db.Date
  percentage      Int
  amountUahMinor  BigInt               @map("amount_uah_minor")
  reason          String               @db.VarChar(300)
  createdById     String               @map("created_by_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  participant     EscortParticipant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  playerProfile   EscortPlayerProfile? @relation(fields: [playerProfileId], references: [id], onDelete: SetNull)
  createdBy       Admin                @relation("EscortPenaltyAdmin", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([playerProfileId, violationDate, sequence])
  @@index([participantId, sequence])
  @@index([createdAt])
  @@index([createdById])
  @@map("escort_penalties")
}

model EscortPlayerProfile {
  id                String              @id @default(uuid())
  gameId            String              @unique @map("game_id") @db.VarChar(20)
  displayName       String              @map("display_name") @db.VarChar(64)
  contact           String?             @db.VarChar(128)
  suspendedUntil    DateTime?           @map("suspended_until")
  permanentlyBanned Boolean             @default(false) @map("permanently_banned")
  bannedAt          DateTime?           @map("banned_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  participants      EscortParticipant[]
  penalties         EscortPenalty[]

  @@index([permanentlyBanned, suspendedUntil])
  @@map("escort_player_profiles")
}

model AdminSession {
  id         String                 @id @default(uuid())
  tokenHash  String                 @unique @map("token_hash") @db.VarChar(64)
  csrfToken  String                 @map("csrf_token") @db.VarChar(128)
  adminId    String                 @map("admin_id")
  accessMode AdminSessionAccessMode @default(observer) @map("access_mode")
  expiresAt  DateTime               @map("expires_at")
  createdAt  DateTime               @default(now()) @map("created_at")
  lastSeenAt DateTime               @default(now()) @map("last_seen_at")
  admin      Admin                  @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@index([accessMode, createdAt])
  @@map("admin_sessions")
}

model Review {
  id            String       @id @default(uuid())
  name          String       @db.VarChar(64)
  contact       String?      @db.VarChar(128)
  rating        Int
  text          String       @db.VarChar(1200)
  status        ReviewStatus @default(pending)
  adminReply    String?      @map("admin_reply") @db.VarChar(1200)
  buyerGameId   String?      @map("buyer_game_id") @db.VarChar(20)
  escortOrderId String?      @unique @map("escort_order_id")
  contentHash   String       @map("content_hash") @db.VarChar(64)
  ipHash        String       @map("ip_hash") @db.VarChar(64)
  createdAt     DateTime     @default(now()) @map("created_at")
  moderatedAt   DateTime?    @map("moderated_at")
  moderatedById String?      @map("moderated_by")
  moderatedBy   Admin?       @relation("ReviewModerator", fields: [moderatedById], references: [id], onDelete: SetNull)
  escortOrder   EscortOrder? @relation(fields: [escortOrderId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([buyerGameId])
  @@index([ipHash, contentHash, createdAt])
  @@map("reviews")
}

model SupportTicket {
  id              String           @id @default(uuid())
  publicNumber    String           @unique @map("public_number") @db.VarChar(24)
  secretTokenHash String           @map("secret_token_hash")
  name            String           @db.VarChar(64)
  contactType     ContactType      @map("contact_type")
  contact         String           @db.VarChar(160)
  category        TicketCategory
  subject         String           @db.VarChar(140)
  status          TicketStatus     @default(open)
  ipHash          String           @map("ip_hash") @db.VarChar(64)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  assignedAdminId String?          @map("assigned_admin_id")
  assignedAdmin   Admin?           @relation("TicketAssignee", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  messages        SupportMessage[]

  @@index([status, createdAt])
  @@index([assignedAdminId])
  @@map("support_tickets")
}

model SupportMessage {
  id            String        @id @default(uuid())
  ticketId      String        @map("ticket_id")
  senderType    MessageSender @map("sender_type")
  senderAdminId String?       @map("sender_admin_id")
  message       String        @db.VarChar(3000)
  createdAt     DateTime      @default(now()) @map("created_at")
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderAdmin   Admin?        @relation("MessageAdmin", fields: [senderAdminId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@map("support_messages")
}

model NotificationLog {
  id          String             @id @default(uuid())
  eventType   String             @map("event_type") @db.VarChar(64)
  destination String             @db.VarChar(128)
  status      NotificationStatus
  error       String?            @db.VarChar(600)
  createdAt   DateTime           @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("notification_logs")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String?  @map("admin_id")
  action     String   @db.VarChar(80)
  entityType String   @map("entity_type") @db.VarChar(64)
  entityId   String?  @map("entity_id") @db.VarChar(64)
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")
  admin      Admin?   @relation("AuditLogAdmin", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([adminId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model ManagerAvailability {
  managerKey String   @id @map("manager_key") @db.VarChar(32)
  busyUntil  DateTime @map("busy_until")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([busyUntil])
  @@map("manager_availability")
}
